# NauticShield Agent — environment config
# Copy this file to .env and fill in your values

# Port the agent HTTP/WebSocket server listens on
PORT=3000

# Local network subnet to scan (without trailing .0)
SUBNET=192.168.1

# How often to run a full network scan (milliseconds)
SCAN_INTERVAL_MS=30000

# Path to the SQLite database file (created automatically)
DB_PATH=./data/vessel.db

# Unique identifier for this vessel (used in cloud sync)
VESSEL_ID=MY_AURORA

# Cloud sync — leave blank to disable
CLOUD_SYNC_URL=https://api.nauticshield.io
CLOUD_API_KEY=
