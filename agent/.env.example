PORT=3001
SCAN_INTERVAL_MS=30000
SYNC_INTERVAL_MS=300000

# Bootstrap a shipped mini PC once, then the agent stores the returned cloud config in data/bootstrap-config.json.
BOOTSTRAP_URL=https://nautic-shield.vercel.app
BOOTSTRAP_TOKEN=

# Optional direct config instead of bootstrap
VESSEL_ID=
VESSEL_NAME=
CLOUD_SYNC_URL=https://nautic-shield.vercel.app
CLOUD_API_KEY=

# Remote shell relay
RELAY_URL=wss://nauticshield-production.up.railway.app
RELAY_SECRET=

# Router enforcement
ROUTER_PLATFORM=openwrt
ROUTER_HOST=192.168.1.1
ROUTER_SSH_USER=root
ROUTER_SSH_KEY_PATH=/home/alex/.ssh/id_ed25519
ROUTER_GUEST_WIFI_SECTION=guest
ROUTER_GUEST_BRIDGE=br-guest
ROUTER_ENFORCE_PENDING=1# NauticShield Agent — environment config
# Copy this file to .env and fill in your values

# Port the agent HTTP/WebSocket server listens on
PORT=3000

# Local network subnet to scan (without trailing .0)
SUBNET=192.168.1

# How often to run a full network scan (milliseconds)
SCAN_INTERVAL_MS=30000

# Path to the SQLite database file (created automatically)
DB_PATH=./data/vessel.db

# Unique identifier for this vessel (used in cloud sync)
VESSEL_ID=MY_AURORA

# Cloud sync — leave blank to disable
CLOUD_SYNC_URL=https://api.nauticshield.io
CLOUD_API_KEY=

# Remote shell relay — leave blank to disable
# RELAY_URL=wss://your-relay.railway.app
# RELAY_SECRET=generate-a-strong-random-secret-here
