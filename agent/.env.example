PORT=3001
SCAN_INTERVAL_MS=30000
SYNC_INTERVAL_MS=300000
DB_PATH=./data/vessel.db
SUBNET=192.168.1

# Bootstrap a shipped mini PC once, then the agent stores the returned cloud config in data/bootstrap-config.json.
# When using bootstrap, leave the direct config values below blank.
BOOTSTRAP_URL=https://nautic-shield.vercel.app
BOOTSTRAP_TOKEN=

# Optional direct config instead of bootstrap
VESSEL_ID=
VESSEL_NAME=
CLOUD_SYNC_URL=
CLOUD_API_KEY=

# Remote shell relay
RELAY_URL=
RELAY_SECRET=

# Router enforcement
ROUTER_PLATFORM=openwrt
ROUTER_HOST=192.168.1.1
ROUTER_SSH_USER=root
ROUTER_SSH_KEY_PATH=/home/alex/.ssh/id_ed25519
ROUTER_GUEST_WIFI_SECTION=guest
ROUTER_GUEST_BRIDGE=br-guest
ROUTER_ENFORCE_PENDING=1

# GNSS anomaly profile tuning
GNSS_PROFILE_MODE=auto
GNSS_ANCHOR_SOG_THRESHOLD=2.5
GNSS_ANOMALY_LOOKBACK_MINUTES=1

GNSS_ANCHOR_MAX_SPEED_KNOTS=28
GNSS_ANCHOR_MAX_POSITION_JUMP_NM=0.7
GNSS_ANCHOR_MIN_SATELLITES=5
GNSS_ANCHOR_SATELLITE_DROP_TRIGGER=4
GNSS_ANCHOR_STATIONARY_SOG_LT=1.8
GNSS_ANCHOR_MISMATCH_KNOTS_GT=12

GNSS_UNDERWAY_MAX_SPEED_KNOTS=75
GNSS_UNDERWAY_MAX_POSITION_JUMP_NM=9.0
GNSS_UNDERWAY_MIN_SATELLITES=4
GNSS_UNDERWAY_SATELLITE_DROP_TRIGGER=5
GNSS_UNDERWAY_STATIONARY_SOG_LT=1.2
GNSS_UNDERWAY_MISMATCH_KNOTS_GT=30
