# NauticShield GNSS pilot baseline profile
# Copy values into agent/.env (or source this file) for pilot operations.

GNSS_PROFILE_MODE=auto
GNSS_ANCHOR_SOG_THRESHOLD=2.5
GNSS_ANOMALY_LOOKBACK_MINUTES=1

GNSS_ANCHOR_MAX_SPEED_KNOTS=28
GNSS_ANCHOR_MAX_POSITION_JUMP_NM=0.7
GNSS_ANCHOR_MIN_SATELLITES=5
GNSS_ANCHOR_SATELLITE_DROP_TRIGGER=4
GNSS_ANCHOR_STATIONARY_SOG_LT=1.8
GNSS_ANCHOR_MISMATCH_KNOTS_GT=12

GNSS_UNDERWAY_MAX_SPEED_KNOTS=75
GNSS_UNDERWAY_MAX_POSITION_JUMP_NM=9.0
GNSS_UNDERWAY_MIN_SATELLITES=4
GNSS_UNDERWAY_SATELLITE_DROP_TRIGGER=5
GNSS_UNDERWAY_STATIONARY_SOG_LT=1.2
GNSS_UNDERWAY_MISMATCH_KNOTS_GT=30

# Edge scan cadence while on pilot
EDGE_SCAN_INTERVAL_MS=300000
EDGE_PORT_TIMEOUT_MS=280
