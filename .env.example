# Frontend local development
# Copy to .env.local and fill in the values you need.

# Local vessel agent URL. Match the agent port you actually run locally.
VITE_AGENT_URL=http://127.0.0.1:3001

# Optional cloud API override.
VITE_CLOUD_API_URL=https://nautic-shield.vercel.app

# Optional vessel scoping for cloud-backed views.
VITE_VESSEL_ID=

# Clerk auth. Leave unset for local dev mode, or paste your real key to test auth flows.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
