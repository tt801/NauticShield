# NauticShield Cloud API — Vercel environment variables
# Add these in the Vercel dashboard under Settings → Environment Variables,
# OR create a .env.local file (never commit it).

# Supabase — from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Clerk — same secret key used by the agent
CLERK_SECRET_KEY=sk_test_...

# Optional: JWKS URL (Clerk provides this automatically, only override if needed)
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
